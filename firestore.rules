rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /prompts/{promptId} {
      allow read: if true;
      allow write: if false; // Solo se puede escribir desde Cloud Functions seguras
    }
    match /login_attempts/{ipHash} {
      allow read, write: if false; // Bloqueo total desde el cliente, solo accesible por Functions Admin
    }
  }
}
